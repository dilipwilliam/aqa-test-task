{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "declaration": true,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@utils/*": ["src/utils/*"],
      "@pages/*": ["src/Tests/page-files/*"],
      "@steps/*": ["src/Tests/step-files/*"],
      "@env/*": ["src/env/*"],
      "@setup/*": ["src/test-setup/*"],
      "@mysql/*": ["MySQL/*"]
    },
    "typeRoots": [
      "node_modules/@types",
      "node_modules/@playwright/test"
    ],
    "types": ["node"],
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "exactOptionalPropertyTypes": false,
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "include": [
    "src/**/*.ts",
    "MySQL/**/*.ts",
    "playwright.config.ts",
    "cucumber.js"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "allure-report",
    "allure-results",
    "test-results"
  ],
  "ts-node": {
    "transpileOnly": true,
    "files": true
  }
}
